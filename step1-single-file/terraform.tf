# =============================================================================
# Terraform & Provider 버전 설정
# =============================================================================
# terraform 블록: Terraform 자체와 사용할 프로바이더의 버전을 고정한다.
#
# 왜 버전을 고정하는가?
#   - Terraform이나 프로바이더가 업데이트되면 동작이 달라질 수 있음
#   - 팀원 모두가 같은 버전을 사용해야 동일한 결과를 보장
#   - 버전을 명시하지 않으면 항상 최신 버전을 받아 예기치 않은 변경 발생 가능
# =============================================================================

terraform {
  required_version = ">= 1.0.0"    # Terraform CLI 최소 버전

  required_providers {
    aws = {
      source  = "hashicorp/aws"     # 프로바이더 출처 (Terraform Registry)
      version = "~> 5.0"            # 5.x 대 버전 사용 (5.0 이상, 6.0 미만)
    }
  }
}
