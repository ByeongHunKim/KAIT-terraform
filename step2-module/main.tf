# =============================================================================
# Step 2: Module화로 재사용성 확보
# =============================================================================
# 학습 목표: 코드 재사용과 변수 사용
#
# 실습:
#   terraform init
#   terraform plan
#   terraform apply
#
# 장점:
#   - 환경별로 다른 값만 변경하면 됨
#   - 모듈 재사용 가능
#
# 남은 불편함:
#   - dev, stg를 동시에 관리하려면 main.tf를 계속 수정해야 함
#   - 환경별 설정이 섞여 있음
#
# 실습 과제:
#   아래 environment를 "stg"로 바꾸고, vpc_cidr을 "10.11.0.0/16"으로
#   변경하여 다른 환경을 만들어보세요.
# =============================================================================

# -----------------------------------------------------------------------------
# VPC Module 호출
# -----------------------------------------------------------------------------
module "vpc" {
  source = "./modules/vpc"

  environment        = "dev"
  vpc_cidr           = "10.10.0.0/16"
  public_subnet_cidr = "10.10.1.0/24"
}

# -----------------------------------------------------------------------------
# Outputs
# -----------------------------------------------------------------------------
output "vpc_id" {
  description = "VPC ID"
  value       = module.vpc.vpc_id
}

output "public_subnet_id" {
  description = "Public Subnet ID"
  value       = module.vpc.public_subnet_id
}
